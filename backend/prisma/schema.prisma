// ============================================
// 1. НАСТРОЙКИ И ПОДКЛЮЧЕНИЯ
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// 2. ГЛОБАЛЬНЫЕ ПЕРЕЧИСЛЕНИЯ (ENUMS)
// ============================================

enum Role {
  CLUB_MEMBER
  TRAINER
  MANAGER
  HR
  DIRECTOR
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum FitnessLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  PRO
}

enum MembershipStatus {
  TRIAL
  ACTIVE
  EXPIRED
}

enum EventType {
  GROUP
  INDIVIDUAL
}

enum EventStatus {
  PENDING_CONFIRMATION
  CONFIRMED
  CANCELLED_BY_TRAINER
  CANCELLED_BY_USER
  COMPLETED
}

enum ParticipantStatus {
  PENDING
  CONFIRMED
  DECLINED
}

enum AttendanceStatus {
  NOT_MARKED
  PRESENT
  ABSENT
  LATE
}

enum RequestType {
  INDIVIDUAL
  GROUP
}

enum RequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
  SCHEDULED
}

// ============================================
// 3. ЯДРО СИСТЕМЫ (ПОЛЬЗОВАТЕЛИ)
// ============================================

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      Role     @default(CLUB_MEMBER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 👇 Единственная связь — с Employee
  employee  Employee?
  clubMember ClubMember? // (это пока оставляем для участников)

  // Обратные связи для заявок и уведомлений
  createdApplications  EmployeeApplication[] @relation("CreatedApplications")
  reviewedApplications EmployeeApplication[] @relation("ReviewedApplications")
  notifications        Notification[]
}

// ============================================
// 4. ПРОФИЛИ ПОЛЬЗОВАТЕЛЕЙ
// ============================================

model ClubMember {
  id          Int      @id @default(autoincrement())
  
  // Личные данные (заполняет участник)
  firstName   String
  lastName    String
  patronymic  String?
  age         Int
  phone       String?
  vk          String?
  telegram    String?
  
  // Данные, назначаемые тренером
  fitnessLevel FitnessLevel? @default(BEGINNER)
  nutritionPlan String?
  
  // Статусы
  membershipStatus MembershipStatus? @default(TRIAL)
  membershipExpiresAt DateTime?
  
  // Связи
  userId      Int      @unique
  user        User     @relation(fields: [userId], references: [id])

   // ✅ Добавляем поле для аватарки
  avatarUrl   String?      // <-- добавляем
  
   // ✅ Добавляем связь с Employee
  trainerId   Int?
  trainer     Employee? @relation(fields: [trainerId], references: [id])
  
  // Интересы (многие-ко-многим)
  interests ClubMemberInterest[]
  
  // Записи на тренировки
  events     EventParticipant[]
  
  // Запросы на тренировки
  trainingRequests TrainingRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


// ============================================
// 5. КАДРОВЫЙ УЧЕТ (ЗАЯВКИ)
// ============================================

model EmployeeApplication {
  id              Int                @id @default(autoincrement())
  email           String
  role            Role
  profileData     Json               // Данные для профиля (зависят от роли)
  status          ApplicationStatus  @default(PENDING)
  rejectionReason String?            // Причина отказа (если REJECTED)

  createdById     Int                // HR, создавший заявку
  createdBy       User               @relation("CreatedApplications", fields: [createdById], references: [id])

  reviewedById    Int?               // Директор, утвердивший/отклонивший
  reviewedBy      User?              @relation("ReviewedApplications", fields: [reviewedById], references: [id])

  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

// ============================================
// ДОЛЖНОСТИ И ГРЕЙДЫ
// ============================================

model Position {
  id                Int      @id @default(autoincrement())
  name              String   @unique
  role              Role              // TRAINER, HR, MANAGER, DIRECTOR
  description       String?
  ratePerTraining   Float?            // для тренеров (за 1 тренировку)
  salesCommission   Float?            // для менеджеров (в %)
  baseSalary        Float?   // <-- добавить, если нужно
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  employees         Employee[]
}

model Grade {
  id                Int      @id @default(autoincrement())
  name              String   @unique // Junior, Middle, Senior, Lead
  baseSalary        Float            // базовый оклад
  bonusRate         Float?   @default(0) // коэффициент премии
  description       String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  employees         Employee[]
}

// ============================================
// СОТРУДНИКИ (расширение User)
// ============================================

model Employee {
  id            Int      @id @default(autoincrement())
  userId        Int      @unique
  user          User     @relation(fields: [userId], references: [id])

  // 👤 Личные данные
  firstName     String
  lastName      String
  patronymic    String?
  phone         String?
  vk            String?
  telegram      String?

  // 💼 Должность и грейд
  positionId    Int
  position      Position @relation(fields: [positionId], references: [id])
  gradeId       Int
  grade         Grade    @relation(fields: [gradeId], references: [id])

  // 💰 Зарплата и график
  currentSalary Float?
  workSchedule  Json?    // { type: "FIXED" | "FLEXIBLE", ... }
  hireDate      DateTime @default(now())
  firedDate     DateTime?
  isActive      Boolean  @default(true)

  // 📎 Аватар и почта
  avatarUrl     String?
  corporateEmail String   @unique

  // 📚 Связи с документами, зарплатами и т.д.
  documents     EmployeeDocument[]
  salaries      Salary[]
  trainerEarnings TrainerEarning[]
  sales         Sale[]

  specialty   String?

  // ✅ Добавляем поле для отдела (для менеджеров)
  department        String?   // <-- добавляем

  events Event[]   // <-- добавляем эту строку
  clubMembers ClubMember[]
}

// ============================================
// ДОКУМЕНТЫ
// ============================================

model DocumentType {
  id                Int      @id @default(autoincrement())
  name              String   @unique // Паспорт, СНИЛС, ИНН, Договор
  description       String?
  isRequired        Boolean  @default(false)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  documents         EmployeeDocument[]
}

model EmployeeDocument {
  id                Int      @id @default(autoincrement())
  employeeId        Int
  employee          Employee @relation(fields: [employeeId], references: [id])
  typeId            Int
  type              DocumentType @relation(fields: [typeId], references: [id])

  fileName          String
  filePath          String
  fileSize          Int
  mimeType          String

  uploadedAt        DateTime @default(now())
  uploadedBy        Int              // User.id

  isVerified        Boolean  @default(false)
  verifiedAt        DateTime?
  verifiedBy        Int?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ============================================
// ЗАРПЛАТА
// ============================================

enum SalaryStatus {
  PENDING
  PAID
  CANCELLED
}

model Salary {
  id                Int      @id @default(autoincrement())
  employeeId        Int
  employee          Employee @relation(fields: [employeeId], references: [id])

  period            String           // "2026-07"
  amount            Float            // сумма к выплате

  baseSalary        Float            // оклад за месяц
  bonus             Float?           // премия/процент
  deductions        Float?   @default(0) // вычеты

  status            SalaryStatus @default(PENDING)
  paidAt            DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ============================================
// ДОХОД ТРЕНЕРА ОТ ТРЕНИРОВОК
// ============================================

model TrainerEarning {
  id                Int      @id @default(autoincrement())
  trainerId         Int
  trainer           Employee @relation(fields: [trainerId], references: [id])
  eventId           Int
  event             Event    @relation(fields: [eventId], references: [id])

  amount            Float            // доход тренера за эту тренировку
  date              DateTime @default(now())

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ============================================
// ПРОДАЖИ (для менеджера)
// ============================================

enum SaleType {
  MEMBERSHIP
  MERCH
  SERVICE
}

model Sale {
  id                Int      @id @default(autoincrement())
  managerId         Int
  manager           Employee @relation(fields: [managerId], references: [id])

  amount            Float
  type              SaleType
  description       String?
  date              DateTime @default(now())

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ============================================
// ФИНАНСЫ (доходы/расходы клуба)
// ============================================

enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionCategory {
  SALE           // продажи
  RENT           // аренда
  SALARY         // зарплаты
  UTILITIES      // коммуналка
  SERVICE        // услуги (массаж, бассейн)
  OTHER
}

model Transaction {
  id                Int      @id @default(autoincrement())
  type              TransactionType
  category          TransactionCategory
  amount            Float
  description       String?
  date              DateTime @default(now())

  createdBy         Int              // User.id
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ============================================
// 6. СИСТЕМА УВЕДОМЛЕНИЙ
// ============================================

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  type      String   // APPLICATION_APPROVED, APPLICATION_REJECTED, NEW_APPLICATION
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ============================================
// 7. БИЗНЕС-МОДУЛИ (ПОСТЫ, КАЛЕНДАРЬ, МАГАЗИН)
// ============================================

model Posts {
  id        Int      @id @default(autoincrement())
  title     String   @default("Без заголовка")
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// БУДУЩИЕ МОДУЛИ (ДЛЯ ПЛАНИРОВАНИЯ)
// ============================================

model TrainingRequest {
  id           Int      @id @default(autoincrement())
  type         RequestType @default(INDIVIDUAL)
  preferredStart DateTime
  preferredEnd   DateTime?
  comment      String?
  preferredLocation String?
  
  // Связи
  clubMemberId Int
  clubMember   ClubMember @relation(fields: [clubMemberId], references: [id])
  trainerId    Int
  
  status       RequestStatus @default(PENDING)
  responseMessage String?
  
  // Если запрос превратился в событие
  eventId      Int?
  event        Event? @relation(fields: [eventId], references: [id])
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Interest {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  clubMembers ClubMemberInterest[]
}

model ClubMemberInterest {
  clubMemberId Int
  interestId   Int
  clubMember   ClubMember @relation(fields: [clubMemberId], references: [id])
  interest     Interest   @relation(fields: [interestId], references: [id])

  @@id([clubMemberId, interestId])
}

model Event {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  type        EventType @default(GROUP)
  startTime   DateTime
  endTime     DateTime
  location    String
  maxParticipants Int @default(10)
  status      EventStatus @default(PENDING_CONFIRMATION)
  completedAt DateTime?
  trainerNote String?
  
  trainerId   Int
  trainer     Employee @relation(fields: [trainerId], references: [id]) // ✅ Employee

  participants EventParticipant[]
  requests    TrainingRequest[]
  trainerEarnings TrainerEarning[] // <-- ДОБАВИТЬ



  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EventParticipant {
  id           Int      @id @default(autoincrement())
  eventId      Int
  event        Event    @relation(fields: [eventId], references: [id])
  clubMemberId Int
  clubMember   ClubMember @relation(fields: [clubMemberId], references: [id])
  status       ParticipantStatus @default(PENDING)
  confirmedBy  String?
  confirmedAt  DateTime?
  attendance   AttendanceStatus? @default(NOT_MARKED)
  markedBy     Int?
  markedAt     DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}


